.env
.env.*
# Cloud Run deploy settings (contains secrets) — never commit.
env.yaml
# Service-account keys / secrets — never commit these.
sa-key.json
*-key.json
*service-account*.json
*credentials*.json
*.pem
# TLS certs / private keys — local dev only, never commit.
*.key
*.crt
cert.key
cert.crt
/my_env
# Python bytecode / caches (any level, not just repo root).
*.pyc
__pycache__/
/db.sqlite3
/venv/
# Collected static output — regenerated by `manage.py collectstatic`.
/staticfiles/
.DS_Store
.idea/
scripts/
